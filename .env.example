# ============================================================
# AgriGPT Agent — Environment Variables
# Copy this file to .env and fill in all values before running.
# Never commit the actual .env file to version control.
# ============================================================


# ── Google AI ────────────────────────────────────────────────
# Gemini API key (required)
GOOGLE_API_KEY=


# ── MCP Servers ──────────────────────────────────────────────
# Alumnx MCP server (pests, govt schemes, SME Divesh tools)
ALUMNX_MCP_URL=
ALUMNX_MCP_API_KEY=        # leave blank if no auth required

# Vignan University MCP server (Vignan RAG tools)
VIGNAN_MCP_URL=
VIGNAN_MCP_API_KEY=        # leave blank if no auth required

# Shared timeout (seconds) for all MCP HTTP calls
MCP_TIMEOUT=30


# ── Alumnx MCP Server internals ──────────────────────────────
# (only needed when running alumnx_mcp_server.py)
PESTS_DISEASES_RAG_URL=
GOVT_SCHEMES_RAG_URL=
RAG_TIMEOUT=30


# ── Pinecone ─────────────────────────────────────────────────
# Shared by both MCP servers
PINECONE_API_KEY=
PINECONE_INDEX=


# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=
MONGODB_DB=agrigpt
MONGODB_COLLECTION=chats


# ── LangSmith (optional) ─────────────────────────────────────
# Set to enable LangGraph tracing in LangSmith
LANGSMITH_API_KEY=


# ── WhatsApp / Meta Cloud API (uncomment when ready) ─────────
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
